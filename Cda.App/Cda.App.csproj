<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>Cda.App</AssemblyName>
    <RootNamespace>Cda.App</RootNamespace>

    <!-- The original tool was x86-only. The modern tool must analyze both
         32-bit and 64-bit targets, so we build for both. The analysis engine
         (added in later phases) must run *in-process-width* with its target,
         so 32-bit targets are driven by an x86 build and 64-bit targets by an
         x64 build. This UI shell itself is bitness-agnostic. -->
    <Platforms>x64;x86</Platforms>
    <PlatformTarget Condition="'$(Platform)' == 'x86'">x86</PlatformTarget>
    <PlatformTarget Condition="'$(Platform)' == 'x64'">x64</PlatformTarget>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- Per-Monitor v2 DPI awareness lives in the manifest below. This is the
         single most important switch for correct 4K/5K rendering: without it a
         .NET WPF app is only System-DPI aware and blurs when moved between
         monitors with different scale factors. -->
    <ApplicationManifest>app.manifest</ApplicationManifest>

    <!-- App icon (the "CDA" monogram, generated by tools\make-icon.ps1). Embedded
         as a Win32 resource in the exe, so Explorer/taskbar show it; WPF also uses
         the application icon for the window chrome when Window.Icon is unset. -->
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cda.Core\Cda.Core.csproj" />
  </ItemGroup>

</Project>
