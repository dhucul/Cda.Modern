<UserControl x:Class="Cda.App.UI.StringsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Surface}">
    <UserControl.Resources>
        <!-- String cell: trims with an ellipsis like the others, but a hover
             tooltip reveals the FULL string so long values are always readable. -->
        <Style x:Key="StringCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="ToolTip" Value="{Binding Display}" />
        </Style>
    </UserControl.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="6">
            <StackPanel>
                <DockPanel>
                    <TextBlock x:Name="MatchInfo" DockPanel.Dock="Right" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,2,0" />
                    <CheckBox x:Name="OnlyReferenced" DockPanel.Dock="Right" Content="Only referenced"
                              IsChecked="False" VerticalAlignment="Center" Margin="8,0,0,0"
                              Foreground="{StaticResource TextSecondary}"
                              Checked="OnOnlyReferencedChanged" Unchecked="OnOnlyReferencedChanged"
                              ToolTip="Off (default): list EVERY string in the module, like IDA's Strings window. Tick to narrow to just the ones some function loads by address (the ones you can jump to)." />
                    <TextBox x:Name="Filter" Padding="4"
                             ToolTip="Search the strings (substring match, case-insensitive)."
                             TextChanged="OnFilterChanged" />
                </DockPanel>
                <TextBlock x:Name="Hint" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,4,0,0"
                           Text="Every string in the module (ASCII + UTF-16), regardless of function — like IDA's Strings window. Double-click one with a known reference to jump to the function that uses it." />
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80" />
                <RowDefinition Height="4" />
                <RowDefinition Height="210" MinHeight="72" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="Grid" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="{StaticResource Surface}" RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource SurfaceAlt}"
                      Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                      CanUserSortColumns="False"
                      SelectionMode="Single" SelectionChanged="OnStringSelectionChanged"
                      MouseDoubleClick="OnStringDoubleClick"
                      FontFamily="Cascadia Mono, Consolas" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="Auto" ElementStyle="{StaticResource GridCellText}" />
                    <DataGridTextColumn Header="T" Binding="{Binding KindGlyph}" Width="28" ElementStyle="{StaticResource GridCellText}" />
                    <DataGridTextColumn Header="String" Binding="{Binding Display}" Width="2*" MinWidth="200" ElementStyle="{StaticResource StringCellStyle}" />
                    <DataGridTextColumn Header="Refs" Binding="{Binding RefCount}" Width="56" ElementStyle="{StaticResource GridCellText}" />
                    <DataGridTextColumn Header="Function" Binding="{Binding PrimaryFunction}" Width="Auto" MaxWidth="260" ElementStyle="{StaticResource GridCellText}" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{StaticResource Outline}" />

            <DockPanel Grid.Row="2">
                <!-- Full value of the selected string — read-only and wrapping, so the
                     WHOLE string (any length) is readable and can be selected/copied.
                     Wraps within the box and scrolls vertically for very long values. -->
                <TextBlock DockPanel.Dock="Top" Text="Selected string (full value):" Margin="8,4,0,0"
                           Foreground="{StaticResource TextMuted}" FontSize="11" />
                <TextBox x:Name="SelectedString" DockPanel.Dock="Top" IsReadOnly="True"
                         TextWrapping="Wrap" MinHeight="40" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource SurfaceAlt}" BorderThickness="0"
                         Foreground="{StaticResource TextPrimary}" Padding="6,3" Margin="6,2,6,0"
                         FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                <TextBlock x:Name="DetailHeader" DockPanel.Dock="Top" Foreground="{StaticResource TextSecondary}"
                           Margin="8,4" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           Text="Referenced by — select a string above." />
                <DataGrid x:Name="DetailGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          Background="{StaticResource Surface}" RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource SurfaceAlt}"
                          Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                          EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                          SelectionMode="Single" SelectionChanged="OnDetailSelectionChanged"
                          FontFamily="Cascadia Mono, Consolas" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Address" Binding="{Binding AddressHex}" Width="Auto" ElementStyle="{StaticResource GridCellText}" />
                        <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="Auto" MaxWidth="200" ElementStyle="{StaticResource GridCellText}" />
                        <DataGridTextColumn Header="Function" Binding="{Binding Name}" Width="*" MinWidth="160" ElementStyle="{StaticResource GridCellText}" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
