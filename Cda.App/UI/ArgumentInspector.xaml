<UserControl x:Class="Cda.App.UI.ArgumentInspector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Surface}">
    <DockPanel>
        <TextBlock x:Name="Header" DockPanel.Dock="Top" Foreground="{StaticResource TextPrimary}"
                   Margin="8,6" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                   Text="No call selected" TextWrapping="Wrap" />
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="None"
                  Background="{StaticResource Surface}" RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource SurfaceAlt}"
                  Foreground="{StaticResource TextPrimary}" BorderThickness="0"
                  FontFamily="Cascadia Mono, Consolas" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" />
                <DataGridTextColumn Header="Register/Slot" Binding="{Binding Slot}" Width="110" />
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="150" />
                <DataGridTextColumn Header="Dereference" Binding="{Binding Deref}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
