<Window x:Class="Cda.App.UI.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vis="clr-namespace:Cda.App.Visualization"
        Title="Compare traces"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Background}">
    <Window.Resources>
        <SolidColorBrush x:Key="MoreBrush"   Color="#3FB950" />
        <SolidColorBrush x:Key="LessBrush"   Color="#F85149" />
        <SolidColorBrush x:Key="ChangeBrush" Color="#E0B341" />

        <!-- Status-cell colouring shared by both tables (keys off the row's Kind). -->
        <Style x:Key="StatusCell" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="onlyA">
                    <Setter Property="Foreground" Value="{StaticResource LessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="onlyB">
                    <Setter Property="Foreground" Value="{StaticResource MoreBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="changed">
                    <Setter Property="Foreground" Value="{StaticResource ChangeBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumCell" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        </Style>
        <Style x:Key="DeltaCell" TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DeltaSign}" Value="pos">
                    <Setter Property="Foreground" Value="{StaticResource MoreBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DeltaSign}" Value="neg">
                    <Setter Property="Foreground" Value="{StaticResource LessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- First-call context: emphasise the selected function itself (the window's centre). -->
        <Style x:Key="CtxCenterCell" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCenter}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="{StaticResource ChangeBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CtxNumCell" TargetType="TextBlock" BasedOn="{StaticResource NumCell}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCenter}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="{StaticResource ChangeBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- Header: the two traces being compared + the headline tally + global actions. -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="HeaderText" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                           FontSize="12.5" />
                <TextBlock x:Name="SummaryText" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"
                           FontSize="12.5" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                <Button Content="Copy report" Padding="12,4" Margin="0,0,8,0" Click="OnCopy"
                        ToolTip="Copy the whole comparison (functions and string arguments) as a text report to the clipboard." />
                <Button Content="Close" Padding="14,4" Click="OnClose" />
            </StackPanel>
        </Grid>

        <TabControl>
            <!-- ============================ Functions & edges ===================== -->
            <TabItem Header="Functions &amp; edges">
                <DockPanel Margin="0,8,0,0">
                    <!-- Filters + thresholds. -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="Filter" Grid.Column="0" Padding="6,4"
                                 ToolTip="Filter by function name or module" TextChanged="OnFilterChanged" />
                        <CheckBox x:Name="ChangesOnly" Grid.Column="1" Content="Differences only" IsChecked="True"
                                  VerticalAlignment="Center" Margin="10,0,0,0" Click="OnChangesOnlyChanged"
                                  ToolTip="Hide functions that ran the same number of times in both traces (the table only — the chart is always differences-only). Identical-count functions are uncommon between two real runs, so this may hide few or no rows." />
                        <TextBlock Grid.Column="2" Text="Min Δ:" VerticalAlignment="Center" Margin="14,0,4,0"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBox x:Name="MinDeltaBox" Grid.Column="3" Width="52" Padding="6,4" VerticalAlignment="Center"
                                 TextChanged="OnMinDeltaChanged"
                                 ToolTip="Hide functions whose call count changed by fewer than this many calls (|Δ| = |callsB − callsA|). Blank or 0 = show every difference. Use it to drop tiny run-to-run wiggles and keep the meaningful changes." />
                        <TextBlock Grid.Column="4" Text="Min %:" VerticalAlignment="Center" Margin="12,0,4,0"
                                   Foreground="{StaticResource TextSecondary}" />
                        <TextBox x:Name="MinPctBox" Grid.Column="5" Width="52" Padding="6,4" VerticalAlignment="Center"
                                 TextChanged="OnMinPctChanged"
                                 ToolTip="Hide functions whose RELATIVE change is below this percent: |Δ| ÷ max(callsA, callsB) × 100. A new or removed function counts as 100% (always shown); a hot function that drifted slightly (e.g. 1000→1010 ≈ 1%) is dropped. Blank or 0 = no percent threshold. Combines with Min Δ (a row must pass both)." />
                        <TextBlock x:Name="MatchInfo" Grid.Column="6" VerticalAlignment="Center" Margin="12,0,4,0"
                                   Foreground="{StaticResource TextMuted}" FontSize="11.5" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" MinWidth="420" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="320" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: the per-function diff table. -->
                        <DataGrid x:Name="Grid" Grid.Column="0"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  FontSize="12" MouseDoubleClick="OnRowDoubleClick"
                                  SelectionChanged="OnSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="86"
                                                    ElementStyle="{StaticResource StatusCell}" />
                                <DataGridTextColumn Header="Function" Binding="{Binding Label}" Width="2*"
                                                    ElementStyle="{StaticResource GridCellText}" />
                                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*"
                                                    ElementStyle="{StaticResource GridCellText}" />
                                <DataGridTextColumn Header="Calls A" Binding="{Binding CountAText}" Width="74"
                                                    SortMemberPath="CountA" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Calls B" Binding="{Binding CountBText}" Width="74"
                                                    SortMemberPath="CountB" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Δ" Binding="{Binding DeltaText}" Width="84"
                                                    SortMemberPath="DeltaValue" ElementStyle="{StaticResource DeltaCell}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch" Background="{StaticResource Outline}" />

                        <!-- Right: the "where they differ" chart. -->
                        <DockPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="WHERE THEY DIFFER" Foreground="{StaticResource TextSecondary}"
                                       FontWeight="SemiBold" FontSize="10.5" Margin="2,0,0,6" />
                            <Border BorderBrush="{StaticResource Outline}" BorderThickness="1" CornerRadius="4">
                                <vis:TraceDiffChart x:Name="Chart" />
                            </Border>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ============================ String arguments ====================== -->
            <TabItem Header="String arguments">
                <DockPanel Margin="0,8,0,0">
                    <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                               FontSize="12" Margin="0,0,0,8"
                               Text="Decoded string arguments passed to hooked calls, and how many times each was seen in A vs B — file paths, registry keys, URLs, format strings a run touched. Matched on the string value itself. Select a string to see WHICH functions received it (below); double-click a function — or the string row — to centre the butterfly graph there and see who passed it." />
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StrFilter" Grid.Column="0" Padding="6,4"
                                 ToolTip="Filter by substring of the string value" TextChanged="OnStrFilterChanged" />
                        <CheckBox x:Name="StrChangesOnly" Grid.Column="1" Content="Differences only" IsChecked="True"
                                  VerticalAlignment="Center" Margin="10,0,0,0" Click="OnStrChangesOnlyChanged"
                                  ToolTip="Hide string arguments seen the same number of times AND by the same functions in both traces. A string with an unchanged total that moved between receiving functions is kept (its 'passed to' breakdown differs)." />
                        <TextBlock x:Name="StrMatchInfo" Grid.Column="2" VerticalAlignment="Center" Margin="12,0,4,0"
                                   Foreground="{StaticResource TextMuted}" FontSize="11.5" />
                    </Grid>

                    <!-- Top: the per-string diff table. Bottom: the functions that received the selected string. -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="120" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0.7*" MinHeight="96" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="StrGrid" Grid.Row="0"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  CanUserResizeRows="False" CanUserReorderColumns="False" FontSize="12"
                                  SelectionChanged="OnStrSelectionChanged" MouseDoubleClick="OnStrRowDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="86"
                                                    ElementStyle="{StaticResource StatusCell}" />
                                <DataGridTextColumn Header="String" Binding="{Binding Value}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                            <Setter Property="ToolTip" Value="{Binding Value}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Seen A" Binding="{Binding CountAText}" Width="74"
                                                    SortMemberPath="CountA" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Seen B" Binding="{Binding CountBText}" Width="74"
                                                    SortMemberPath="CountB" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Δ" Binding="{Binding DeltaText}" Width="84"
                                                    SortMemberPath="DeltaValue" ElementStyle="{StaticResource DeltaCell}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center" Background="{StaticResource Outline}" />

                        <DockPanel Grid.Row="2" Margin="0,6,0,0">
                            <TextBlock x:Name="SiteHeader" DockPanel.Dock="Top" Margin="2,0,0,6"
                                       Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" FontSize="10.5"
                                       Text="PASSED TO — SELECT A STRING ABOVE" />
                            <DataGrid x:Name="SiteGrid"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" SelectionMode="Single"
                                      CanUserResizeRows="False" CanUserReorderColumns="False" FontSize="12"
                                      MouseDoubleClick="OnSiteRowDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="86"
                                                        ElementStyle="{StaticResource StatusCell}" />
                                    <DataGridTextColumn Header="Function (received it)" Binding="{Binding Label}" Width="2*"
                                                        ElementStyle="{StaticResource GridCellText}" />
                                    <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*"
                                                        ElementStyle="{StaticResource GridCellText}" />
                                    <DataGridTextColumn Header="Seen A" Binding="{Binding CountAText}" Width="74"
                                                        SortMemberPath="CountA" ElementStyle="{StaticResource NumCell}" />
                                    <DataGridTextColumn Header="Seen B" Binding="{Binding CountBText}" Width="74"
                                                        SortMemberPath="CountB" ElementStyle="{StaticResource NumCell}" />
                                    <DataGridTextColumn Header="Δ" Binding="{Binding DeltaText}" Width="84"
                                                        SortMemberPath="DeltaValue" ElementStyle="{StaticResource DeltaCell}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ============================ First-call order ====================== -->
            <TabItem Header="First-call order">
                <DockPanel Margin="0,8,0,0">
                    <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                               FontSize="12" Margin="0,0,0,8"
                               Text="The order functions were FIRST called in each run, aligned by longest-common-subsequence so a cascade doesn't masquerade as a reorder. 'in order' = kept its relative position (even if its rank shifted because other functions were added/removed); 'moved' = genuinely reordered; 'only A' / 'only B' = called in just one run. Rank A/B are the first-call positions (1 = first); Δ rank = rankB − rankA. Select a row to see WHAT each run called around it (below); double-click a function — here or below — to centre the butterfly graph there." />
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OrderFilter" Grid.Column="0" Padding="6,4"
                                 ToolTip="Filter by function name or module" TextChanged="OnOrderFilterChanged" />
                        <CheckBox x:Name="OrderChangesOnly" Grid.Column="1" Content="Differences only" IsChecked="True"
                                  VerticalAlignment="Center" Margin="10,0,0,0" Click="OnOrderChangesOnlyChanged"
                                  ToolTip="Hide functions that kept their relative first-call order ('in order') — show only the genuinely moved and the only-in-one-run functions." />
                        <TextBlock x:Name="OrderMatchInfo" Grid.Column="2" VerticalAlignment="Center" Margin="12,0,4,0"
                                   Foreground="{StaticResource TextMuted}" FontSize="11.5" />
                    </Grid>

                    <!-- Top: the first-call diff table. Bottom: what each run called around the selected function. -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="120" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0.7*" MinHeight="110" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="OrderGrid" Grid.Row="0"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  CanUserResizeRows="False" CanUserReorderColumns="False"
                                  FontSize="12" MouseDoubleClick="OnOrderRowDoubleClick"
                                  SelectionChanged="OnOrderSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="86"
                                                    ElementStyle="{StaticResource StatusCell}" />
                                <DataGridTextColumn Header="Function" Binding="{Binding Label}" Width="2*"
                                                    ElementStyle="{StaticResource GridCellText}" />
                                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*"
                                                    ElementStyle="{StaticResource GridCellText}" />
                                <DataGridTextColumn Header="Rank A" Binding="{Binding RankAText}" Width="74"
                                                    SortMemberPath="RankASort" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Rank B" Binding="{Binding RankBText}" Width="74"
                                                    SortMemberPath="RankBSort" ElementStyle="{StaticResource NumCell}" />
                                <DataGridTextColumn Header="Δ rank" Binding="{Binding RankDeltaText}" Width="74"
                                                    SortMemberPath="RankDeltaSort" ElementStyle="{StaticResource NumCell}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center" Background="{StaticResource Outline}" />

                        <DockPanel Grid.Row="2" Margin="0,6,0,0">
                            <TextBlock x:Name="OrderCtxHeader" DockPanel.Dock="Top" Margin="2,0,0,6"
                                       Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" FontSize="10.5"
                                       Text="FIRST-CALL CONTEXT — SELECT A FUNCTION ABOVE" />
                            <!-- Side by side: the selected function's neighbourhood in A's order vs B's order. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DockPanel Grid.Column="0">
                                    <TextBlock x:Name="OrderCtxAHeader" DockPanel.Dock="Top" Margin="2,0,0,4"
                                               Foreground="{StaticResource TextMuted}" FontSize="10" Text="AROUND IT IN A" />
                                    <DataGrid x:Name="OrderCtxA"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              HeadersVisibility="Column" SelectionMode="Single"
                                              CanUserResizeRows="False" CanUserReorderColumns="False" FontSize="12"
                                              MouseDoubleClick="OnOrderCtxADoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding RankText}" Width="44"
                                                                ElementStyle="{StaticResource CtxNumCell}" />
                                            <DataGridTextColumn Header="Function" Binding="{Binding Label}" Width="2*"
                                                                ElementStyle="{StaticResource CtxCenterCell}" />
                                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*"
                                                                ElementStyle="{StaticResource CtxCenterCell}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>

                                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                                              VerticalAlignment="Stretch" Background="{StaticResource Outline}" />

                                <DockPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock x:Name="OrderCtxBHeader" DockPanel.Dock="Top" Margin="2,0,0,4"
                                               Foreground="{StaticResource TextMuted}" FontSize="10" Text="AROUND IT IN B" />
                                    <DataGrid x:Name="OrderCtxB"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              HeadersVisibility="Column" SelectionMode="Single"
                                              CanUserResizeRows="False" CanUserReorderColumns="False" FontSize="12"
                                              MouseDoubleClick="OnOrderCtxBDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding RankText}" Width="44"
                                                                ElementStyle="{StaticResource CtxNumCell}" />
                                            <DataGridTextColumn Header="Function" Binding="{Binding Label}" Width="2*"
                                                                ElementStyle="{StaticResource CtxCenterCell}" />
                                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*"
                                                                ElementStyle="{StaticResource CtxCenterCell}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
